{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile and real-time location data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "timestamp": { "type": "string", "format": "date-time" }
          }
        },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "TrackingRequest": {
      "title": "Tracking Request",
      "description": "A request to track someone's location.",
      "type": "object",
      "properties": {
        "fromUid": { "type": "string" },
        "fromEmail": { "type": "string" },
        "toEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromUid", "toEmail", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles and locations."
    },
    "/tracking_requests/{requestId}": {
      "schema": "TrackingRequest",
      "description": "Requests to share location."
    }
  }
}
