{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "env": {
    "GEMINI_API_KEY": "@gemini_api_key",
    "APP_URL": "@app_url"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
